digraph LexicalAnalyzer {
    node [shape=circle];
    0 [color="green", label="START"];
    1 [label="IDENT", peripheries = 2];
    2 [label="NUM", peripheries = 2];
    3 [label="COMMENT_BODY"];
    4 [label="COMMENT", peripheries = 2];
    6 [label="IDENT", peripheries = 2];
    7 [label="IDENT", peripheries = 2];
    8 [label="IDENT", peripheries = 2];
    9 [label="PLUS", peripheries = 2];
    10 [label="IDENT", peripheries = 2];
    11 [label="IDENT", peripheries = 2];
    12 [label="IDENT", peripheries = 2];
    13 [label="IDENT", peripheries = 2];
    14 [label="MINUS", peripheries = 2];
    15 [label="GT"];
    16 [label="GE", peripheries = 2];
    17 [label="LT"];
    18 [label="LE", peripheries = 2];
    19 [label="ASSIGN"];
    20 [label="EQ", peripheries = 2];

    0 -> 1 [label="[a-lnq-zA-Z]"];
    1 -> 1 [label="[a-zA-Z0-9]"];
    
    0 -> 2 [label="0-9"];
    2 -> 2 [label="0-9"];
    
    0 -> 3 [label="'"];
    3 -> 3 [label="[^\\n]"];
    3 -> 4 [label="\\n"];
    
    
    0 -> 6 [label="p"];
    6 -> 7 [label="l"];
    6 -> 1 [label="[a-km-zA-Z0-9]"];
    7 -> 8 [label="u"];
    7 -> 1 [label="[a-tv-zA-Z0-9]"];
    8 -> 9 [label="s"];
    8 -> 1 [label="[a-rt-zA-Z0-9]"];
    
    0 -> 10 [label="m"];
    10 -> 11 [label="i"];
    10 -> 1 [label="[a-hj-zA-Z0-9]"];
    11 -> 12 [label="n"];
    11 -> 1 [label="[a-mo-zA-Z0-9]"];
    12 -> 13 [label="u"];
    12 -> 1 [label="[a-tv-zA-Z0-9]"];
    13 -> 14 [label="s"];
    13 -> 1 [label="[a-rt-zA-Z0-9]"];
    
    0 -> 15 [label=">"];
    15 -> 16 [label="="];
    
    0 -> 17 [label="<"];
    17 -> 18 [label="="];
    
    0 -> 19 [label="="];
    19 -> 20 [label="="];
    
    9 -> 1 [label="[a-zA-Z0-9]"];
    14 -> 1 [label="[a-zA-Z0-9]"];
}

